### Register professor
POST http://localhost:8080/auth/register
Content-Type: application/json

{
  "email": "prof@isel.pt",
  "password": "secret",
  "role": "PROFESSOR"
}

> {%
  client.global.set("prof_token", response.body.token);
  client.global.set("prof_id", response.body.userId);
%}

### Login professor
POST http://localhost:8080/auth/login
Content-Type: application/json

{
  "email": "prof@isel.pt",
  "password": "secret"
}

> {%
  client.global.set("prof_token", response.body.token);
%}

### Create exam
POST http://localhost:8080/exams
Content-Type: application/json
Authorization: Bearer {{prof_token}}

{
  "title": "Networks",
  "durationMins": 90
}

> {%
  client.global.set("exam_id", response.body.id);
%}

### Create session
POST http://localhost:8080/sessions
Content-Type: application/json
Authorization: Bearer {{prof_token}}

{
  "examId": "{{exam_id}}"
}

> {%
  client.global.set("session_id", response.body.id);
  client.global.set("session_code", response.body.code);
%}

### Start session
POST http://localhost:8080/sessions/{{session_id}}/start
Authorization: Bearer {{prof_token}}

### Get session
GET http://localhost:8080/sessions/{{session_id}}
Authorization: Bearer {{prof_token}}

### Get participants
GET http://localhost:8080/sessions/{{session_id}}/participants
Authorization: Bearer {{prof_token}}

### Register student
POST http://localhost:8080/auth/register
Content-Type: application/json

{
  "email": "student@alunos.isel.pt",
  "password": "pass",
  "role": "STUDENT"
}

> {%
  client.global.set("student_token", response.body.token);
%}

### Student joins session
POST http://localhost:8080/sessions/join
Content-Type: application/json
Authorization: Bearer {{student_token}}

{
  "code": "{{session_code}}"
}

> {%
  client.global.set("participant_id", response.body.participantId);
%}

### Heartbeat
POST http://localhost:8080/participants/{{participant_id}}/heartbeat
Authorization: Bearer {{student_token}}

### End session
POST http://localhost:8080/sessions/{{session_id}}/end
Authorization: Bearer {{prof_token}}
